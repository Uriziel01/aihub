---
import PageLayout from '../layouts/PageLayout.astro';
import TopicCard from '../components/TopicCard.astro';

const base = import.meta.env.BASE_URL;

const featuredTopics = [
  {
    title: 'Neural Networks',
    description: 'Discover how AI learns by mimicking the human brain, from basic perceptrons to deep learning architectures.',
    href: `${base}/topics/neural-networks`,
    tags: ['Deep Learning', 'Fundamentals'],
    level: 'all' as const,
    emoji: '🧠',
  },
  {
    title: 'Large Language Models',
    description: 'Understand the technology powering ChatGPT, Claude, and other modern AI assistants.',
    href: `${base}/topics/large-language-models`,
    tags: ['NLP', 'GPT', 'Transformers'],
    level: 'all' as const,
    emoji: '💬',
  },
  {
    title: 'Machine Learning Basics',
    description: 'How computers learn patterns from data without being explicitly programmed — the foundation of AI.',
    href: `${base}/topics`,
    tags: ['ML', 'Fundamentals', 'Statistics'],
    level: 'beginner' as const,
    emoji: '📊',
  },
  {
    title: 'Transformer Architecture',
    description: 'The revolutionary "Attention is All You Need" architecture that underpins modern AI breakthroughs.',
    href: `${base}/topics`,
    tags: ['Architecture', 'Attention', 'NLP'],
    level: 'expert' as const,
    emoji: '⚙️',
  },
  {
    title: 'Reinforcement Learning',
    description: 'Teaching AI through reward and punishment — the technique behind game-playing AIs and robotics.',
    href: `${base}/topics`,
    tags: ['RL', 'Reward', 'Policy'],
    level: 'intermediate' as const,
    emoji: '🎮',
  },
  {
    title: 'Computer Vision',
    description: 'How AI perceives and understands images and video — from face recognition to self-driving cars.',
    href: `${base}/topics`,
    tags: ['CNN', 'Images', 'Vision'],
    level: 'intermediate' as const,
    emoji: '👁️',
  },
];

const categories = [
  { emoji: '🧠', label: 'Foundations', count: 12 },
  { emoji: '💬', label: 'NLP & LLMs', count: 18 },
  { emoji: '👁️', label: 'Computer Vision', count: 9 },
  { emoji: '🎮', label: 'Reinforcement Learning', count: 7 },
  { emoji: '🤖', label: 'Robotics & Embodied AI', count: 5 },
  { emoji: '🔐', label: 'AI Safety & Ethics', count: 11 },
  { emoji: '📐', label: 'Math & Theory', count: 14 },
  { emoji: '🛠️', label: 'Tools & Frameworks', count: 8 },
];
---

<PageLayout title="AIHub" description="The AI Encyclopedia — knowledge at every level." activeNav="home">

  <!-- Hero -->
  <section style="position:relative;overflow:hidden;padding:6rem 1.5rem 5rem;text-align:center;">
    <div class="hero-glow" style="top:-200px;left:50%;transform:translateX(-50%);"></div>
    <div class="hero-glow" style="top:0;left:20%;opacity:0.6;width:400px;height:400px;background:radial-gradient(circle,rgba(6,182,212,0.08) 0%,transparent 70%);"></div>

    <div style="position:relative;max-width:800px;margin:0 auto;">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.35rem 0.85rem;background:var(--color-primary-light);border:1px solid var(--color-intermediate-border);border-radius:9999px;font-size:0.78rem;font-weight:600;color:var(--color-primary);margin-bottom:1.5rem;">
        <span>✨</span>
        <span>Open AI Knowledge for Everyone</span>
      </div>

      <h1 style="font-size:clamp(2.5rem,6vw,4.5rem);font-weight:800;line-height:1.1;margin-bottom:1.25rem;">
        The AI Encyclopedia<br />
        <span class="gradient-text">for Every Mind</span>
      </h1>

      <p style="font-size:clamp(1rem,2.5vw,1.25rem);color:var(--color-text-muted);max-width:580px;margin:0 auto 2.5rem;line-height:1.65;">
        Whether you're a curious newcomer, a hands-on practitioner, or a seasoned researcher —
        AIHub explains AI at <em>your</em> level.
      </p>

      <!-- Search bar -->
      <div style="max-width:520px;margin:0 auto 2rem;position:relative;">
        <svg style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:var(--color-text-subtle);pointer-events:none;" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="search"
          placeholder="Search AI topics… try 'neural network' or 'GPT'"
          class="search-input"
          style="padding-left:3rem;padding-right:6rem;font-size:0.95rem;"
          id="hero-search"
          aria-label="Search AI topics"
        />
        <kbd style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);font-size:0.72rem;padding:0.15rem 0.4rem;background:var(--color-bg-subtle);border:1px solid var(--color-border);border-radius:5px;color:var(--color-text-subtle);">⌘K</kbd>
      </div>

      <!-- Level quick-select -->
      <div style="display:flex;align-items:center;justify-content:center;gap:0.75rem;flex-wrap:wrap;">
        <span style="font-size:0.82rem;color:var(--color-text-subtle);">Start at your level:</span>
        <a href={`${base}/topics/neural-networks`} style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.4rem 1rem;background:var(--color-beginner-bg);border:1px solid var(--color-beginner-border);border-radius:9999px;font-size:0.82rem;font-weight:600;color:var(--color-beginner);text-decoration:none;transition:all 0.15s;">🌱 Beginner</a>
        <a href={`${base}/topics/neural-networks`} style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.4rem 1rem;background:var(--color-intermediate-bg);border:1px solid var(--color-intermediate-border);border-radius:9999px;font-size:0.82rem;font-weight:600;color:var(--color-intermediate);text-decoration:none;transition:all 0.15s;">⚡ Intermediate</a>
        <a href={`${base}/topics/neural-networks`} style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.4rem 1rem;background:var(--color-expert-bg);border:1px solid var(--color-expert-border);border-radius:9999px;font-size:0.82rem;font-weight:600;color:var(--color-expert);text-decoration:none;transition:all 0.15s;">🔬 Expert</a>
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <section style="border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);background:var(--color-bg-card);">
    <div style="max-width:1280px;margin:0 auto;padding:1.5rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1rem;text-align:center;">
      {[
        ['84+', 'AI Topics'],
        ['3', 'Knowledge Levels'],
        ['120+', 'Code Snippets'],
        ['60+', 'Research Papers'],
      ].map(([num, label]) => (
        <div>
          <div style="font-size:1.75rem;font-weight:800;color:var(--color-primary);">{num}</div>
          <div style="font-size:0.82rem;color:var(--color-text-muted);">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section style="max-width:1280px;margin:0 auto;padding:5rem 1.5rem 2rem;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2 style="font-size:2rem;font-weight:800;margin-bottom:0.75rem;">One topic, three depths</h2>
      <p style="font-size:1rem;color:var(--color-text-muted);max-width:500px;margin:0 auto;">Every article adapts to your knowledge level. Switch anytime — the content updates instantly.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;">
      {[
        {
          level: 'beginner',
          badge: 'badge-beginner',
          icon: '🌱',
          title: 'Beginner',
          who: 'Your mum, a product manager, anyone curious',
          desc: "Plain language, real-world analogies, zero jargon. We explain AI like you'd explain it to a smart friend over coffee.",
          example: '"A neural network is like a voting committee — many simple opinions combine to make a smart decision."',
        },
        {
          level: 'intermediate',
          badge: 'badge-intermediate',
          icon: '⚡',
          title: 'Intermediate',
          who: 'Developers, data enthusiasts, AI users',
          desc: "Core concepts with technical terms, architecture diagrams, and practical examples. You've heard of GPT — now understand how it works.",
          example: '"Attention mechanisms let the model focus on relevant parts of the input, weighted by learned similarity scores."',
        },
        {
          level: 'expert',
          badge: 'badge-expert',
          icon: '🔬',
          title: 'Expert',
          who: 'ML engineers, researchers, PhD students',
          desc: 'Full depth: math notation, pseudocode, links to original papers, implementation details, and edge cases.',
          example: '"Attention(Q,K,V) = softmax(QKᵀ/√dₖ)V — scaled to prevent vanishing gradients in high dimensions."',
        },
      ].map(card => (
        <div class="card" style="padding:1.75rem;">
          <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:1rem;">
            <span style="font-size:1.5rem;">{card.icon}</span>
            <span class={`badge ${card.badge}`}>{card.title}</span>
          </div>
          <div style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-text-subtle);margin-bottom:0.4rem;">Best for</div>
          <div style="font-size:0.85rem;font-weight:600;color:var(--color-text);margin-bottom:0.75rem;">{card.who}</div>
          <p style="font-size:0.85rem;color:var(--color-text-muted);margin-bottom:1rem;">{card.desc}</p>
          <blockquote style="font-size:0.8rem;font-style:italic;color:var(--color-text-subtle);border-left:2px solid var(--color-border);padding-left:0.75rem;margin:0;">{card.example}</blockquote>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured Topics -->
  <section style="max-width:1280px;margin:0 auto;padding:3rem 1.5rem;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem;flex-wrap:wrap;gap:1rem;">
      <div>
        <h2 style="font-size:1.75rem;font-weight:800;margin-bottom:0.25rem;">Featured Topics</h2>
        <p style="font-size:0.9rem;color:var(--color-text-muted);">Start with the most popular concepts in AI</p>
      </div>
      <a href={`${base}/topics`} class="btn btn-secondary">Browse all topics →</a>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem;">
      {featuredTopics.map(topic => (
        <TopicCard {...topic} />
      ))}
    </div>
  </section>

  <!-- Categories -->
  <section style="max-width:1280px;margin:0 auto;padding:3rem 1.5rem;">
    <h2 style="font-size:1.75rem;font-weight:800;margin-bottom:1.75rem;">Browse by Category</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.75rem;">
      {categories.map(cat => (
        <a href={`${base}/topics`} style="display:flex;align-items:center;gap:0.75rem;padding:0.875rem 1rem;background:var(--color-bg-card);border:1px solid var(--color-border);border-radius:10px;text-decoration:none;transition:all 0.15s;" onmouseover="this.style.borderColor='var(--color-primary)';this.style.transform='translateY(-1px)'" onmouseout="this.style.borderColor='var(--color-border)';this.style.transform='none'">
          <span style="font-size:1.4rem;">{cat.emoji}</span>
          <div>
            <div style="font-size:0.875rem;font-weight:600;color:var(--color-text);">{cat.label}</div>
            <div style="font-size:0.75rem;color:var(--color-text-subtle);">{cat.count} articles</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section style="max-width:1280px;margin:3rem auto;padding:0 1.5rem 4rem;">
    <div style="background:linear-gradient(135deg,var(--color-primary-light) 0%,var(--color-expert-bg) 100%);border:1px solid var(--color-intermediate-border);border-radius:20px;padding:3rem 2rem;text-align:center;position:relative;overflow:hidden;">
      <div style="position:absolute;top:-60px;right:-60px;width:200px;height:200px;background:radial-gradient(circle,rgba(79,70,229,0.15) 0%,transparent 70%);pointer-events:none;"></div>
      <h2 style="font-size:1.75rem;font-weight:800;margin-bottom:0.75rem;">Ready to explore AI?</h2>
      <p style="font-size:1rem;color:var(--color-text-muted);max-width:460px;margin:0 auto 2rem;">Start with a real article. Try Neural Networks — the building block of modern AI.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href={`${base}/topics/neural-networks`} class="btn btn-primary" style="font-size:0.95rem;padding:0.65rem 1.5rem;">🧠 Read: Neural Networks</a>
        <a href={`${base}/topics`} class="btn btn-secondary" style="font-size:0.95rem;padding:0.65rem 1.5rem;">Browse all topics</a>
      </div>
    </div>
  </section>

</PageLayout>
