                    ['Sigmoid', 'σ(x) = 1/(1+e⁻ˣ)', 'Binary classification output', 'Vanishing gradients'],
                    ['ReLU', 'max(0, x)', 'Hidden layers (default)', 'Dead neurons'],
                    ['GELU', '≈ x·Φ(x)', 'Transformers, BERT, GPT', 'Computationally heavier'],
                    ['Softmax', 'eˣⁱ / Σeˣʲ', 'Multi-class output', 'Not for hidden layers'],
