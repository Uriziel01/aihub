        <a href={`${base}/topics`} class="btn btn-secondary">All Topics →</a>
      </div>

    </article>

    <!-- Right sidebar -->
    <aside style="grid-column:3;position:sticky;top:80px;align-self:start;" class="hide-mobile">
      <div style="background:var(--color-bg-card);border:1px solid var(--color-border);border-radius:12px;padding:1.25rem;margin-bottom:1rem;">
        <p style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text-subtle);margin-bottom:0.75rem;">Quick Facts</p>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.75rem;font-size:0.82rem;">
          <li><span style="color:var(--color-text-subtle);">Architecture</span><br/><strong>Transformer (decoder)</strong></li>
          <li><span style="color:var(--color-text-subtle);">Introduced</span><br/><strong>GPT-1, 2018</strong></li>
          <li><span style="color:var(--color-text-subtle);">Training</span><br/><strong>Self-supervised + RLHF</strong></li>
          <li><span style="color:var(--color-text-subtle);">Largest public</span><br/><strong>~1T parameters (est.)</strong></li>
        </ul>
      </div>
      <div style="background:var(--color-primary-light);border:1px solid var(--color-intermediate-border);border-radius:12px;padding:1.25rem;">
