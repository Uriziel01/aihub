---
import PageLayout from '../layouts/PageLayout.astro';
import Callout from '../components/Callout.astro';
import CodeBlock from '../components/CodeBlock.astro';
import TopicCard from '../components/TopicCard.astro';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="UI Elements"
  description="Complete design system and component showcase for AIHub."
  activeNav="elements"
>
  <div style="max-width:1100px;margin:0 auto;padding:3rem 1.5rem;">

    <!-- Header -->
    <div style="margin-bottom:3rem;padding-bottom:2rem;border-bottom:1px solid var(--color-border);">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.3rem 0.75rem;background:var(--color-expert-bg);border:1px solid var(--color-expert-border);border-radius:9999px;font-size:0.78rem;font-weight:600;color:var(--color-expert);margin-bottom:1rem;">
        🎨 Design System
      </div>
      <h1 style="font-size:2.5rem;font-weight:800;margin-bottom:0.5rem;">UI Elements</h1>
      <p style="font-size:1.05rem;color:var(--color-text-muted);">All components, tokens, and patterns used across AIHub — your template reference.</p>
    </div>

    <!-- Page nav -->
    <nav style="margin-bottom:3rem;" aria-label="Elements navigation">
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
        {[
          ['#colors', '🎨 Colors'],
          ['#typography', '📝 Typography'],
          ['#buttons', '🔘 Buttons'],
          ['#badges', '🏷 Badges'],
          ['#cards', '📦 Cards'],
          ['#callouts', '💡 Callouts'],
          ['#code', '💻 Code'],
          ['#forms', '📋 Forms'],
          ['#tables', '📊 Tables'],
          ['#levels', '🎓 Level Selector'],
          ['#dark-mode', '🌙 Dark Mode'],
        ].map(([href, label]) => (
          <a href={href} class="tag" style="text-decoration:none;transition:all 0.1s;" onmouseover="this.style.borderColor='var(--color-primary)';this.style.color='var(--color-primary)'" onmouseout="this.style.borderColor='var(--color-border)';this.style.color='var(--color-text-muted)'">{label}</a>
        ))}
      </div>
    </nav>

    <!-- ─── COLORS ─── -->
    <section id="colors" style="margin-bottom:4rem;">
      <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:0.4rem;">Colors</h2>
      <p style="font-size:0.9rem;color:var(--color-text-muted);margin-bottom:1.5rem;">CSS custom properties that adapt between light and dark modes automatically.</p>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:0.75rem;margin-bottom:1.5rem;">
        {[
          { name: '--color-bg', label: 'Background' },
          { name: '--color-bg-card', label: 'Card BG' },
          { name: '--color-bg-subtle', label: 'Subtle BG' },
          { name: '--color-border', label: 'Border' },
          { name: '--color-text', label: 'Text' },
          { name: '--color-text-muted', label: 'Muted Text' },
          { name: '--color-primary', label: 'Primary' },
          { name: '--color-accent', label: 'Accent' },
          { name: '--color-beginner', label: 'Beginner' },
          { name: '--color-intermediate', label: 'Intermediate' },
          { name: '--color-expert', label: 'Expert' },
        ].map(c => (
          <div style="border-radius:10px;overflow:hidden;border:1px solid var(--color-border);">
            <div style={`height:52px;background:var(${c.name});`}></div>
            <div style="padding:0.5rem 0.65rem;background:var(--color-bg-card);">
              <div style="font-size:0.72rem;font-weight:700;color:var(--color-text);margin-bottom:0.1rem;">{c.label}</div>
              <div style="font-size:0.65rem;color:var(--color-text-subtle);font-family:'JetBrains Mono',monospace;">{c.name}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── TYPOGRAPHY ─── -->
    <section id="typography" style="margin-bottom:4rem;">
      <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;">Typography</h2>
      <div class="card" style="padding:2rem;">
        <div style="font-size:2.5rem;font-weight:800;line-height:1.1;margin-bottom:0.5rem;">Heading 1 — Inter 800</div>
        <div style="font-size:2rem;font-weight:800;line-height:1.15;margin-bottom:0.5rem;">Heading 2 — Inter 800</div>
        <div style="font-size:1.5rem;font-weight:700;margin-bottom:0.5rem;">Heading 3 — Inter 700</div>
        <div style="font-size:1.25rem;font-weight:700;margin-bottom:0.5rem;">Heading 4 — Inter 700</div>
        <div style="font-size:1rem;color:var(--color-text-muted);margin-bottom:0.5rem;">Body — Inter Regular 400. For paragraphs, descriptions, and general content. Line height 1.6 for comfortable reading.</div>
        <div style="font-size:0.875rem;color:var(--color-text-muted);margin-bottom:0.5rem;">Small — 0.875rem. Used for captions, metadata, UI labels.</div>
        <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;font-weight:700;color:var(--color-text-subtle);">Overline — 0.75rem uppercase. For section labels.</div>
        <div style="margin-top:1rem;padding:0.75rem 1rem;background:var(--color-code-bg);border-radius:8px;font-family:'JetBrains Mono',monospace;font-size:0.875rem;color:var(--color-code-text);">Code — JetBrains Mono. For inline code, terminal output, filenames.</div>
        <div style="margin-top:1rem;" class="gradient-text" style="font-size:1.75rem;font-weight:800;">Gradient Text Effect</div>
      </div>
    </section>

    <!-- ─── BUTTONS ─── -->
    <section id="buttons" style="margin-bottom:4rem;">
      <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;">Buttons</h2>
      <div class="card" style="padding:2rem;">
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;margin-bottom:1.5rem;align-items:center;">
          <button class="btn btn-primary">Primary Button</button>
          <button class="btn btn-secondary">Secondary</button>
          <button class="btn btn-ghost">Ghost</button>
          <button class="btn btn-primary" disabled style="opacity:0.5;cursor:not-allowed;">Disabled</button>
        </div>

        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;margin-bottom:1.5rem;align-items:center;">
          <button class="btn btn-primary" style="font-size:1rem;padding:0.65rem 1.5rem;">Large Primary</button>
          <button class="btn btn-primary">Default Primary</button>
          <button class="btn btn-primary" style="font-size:0.75rem;padding:0.3rem 0.85rem;">Small</button>
        </div>

        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;align-items:center;">
          <button class="btn btn-primary">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            With Icon
          </button>
          <button class="btn btn-secondary">
            Browse Topics
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
          <a href="#" class="btn btn-primary" style="text-decoration:none;">Link as Button</a>
        </div>
      </div>
    </section>

    <!-- ─── BADGES ─── -->
    <section id="badges" style="margin-bottom:4rem;">
      <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;">Badges & Tags</h2>
      <div class="card" style="padding:2rem;">
        <div style="margin-bottom:1.5rem;">
          <p style="font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-text-subtle);margin-bottom:0.75rem;">Knowledge Level Badges</p>
          <div style="display:flex;flex-wrap:wrap;gap:0.75rem;align-items:center;">
            <span class="badge badge-beginner">🌱 Beginner</span>
            <span class="badge badge-intermediate">⚡ Intermediate</span>
            <span class="badge badge-expert">🔬 Expert</span>
            <span class="badge badge-intermediate">🎓 All Levels</span>
          </div>
        </div>
        <div>
          <p style="font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-text-subtle);margin-bottom:0.75rem;">Topic Tags</p>
          <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
            {['Deep Learning', 'NLP', 'Transformers', 'Computer Vision', 'PyTorch', 'Research', 'Math', 'Tutorial'].map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ─── CARDS ─── -->
    <section id="cards" style="margin-bottom:4rem;">
      <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;">Topic Cards</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.25rem;">
        <TopicCard
          title="Neural Networks"
          description="The fundamental building block of modern AI — layers of nodes that learn from data."
          href={`${base}/topics/neural-networks`}
          tags={['Deep Learning', 'Fundamentals']}
          level="all"
          emoji="🧠"
        />
        <TopicCard
          title="Prompt Engineering"
          description="Get the best results from AI models by crafting effective prompts and instructions."
          href={`${base}/topics`}
          tags={['LLMs', 'Practical']}
          level="beginner"
          emoji="✍️"
        />
        <TopicCard
          title="Transformer Architecture"
          description="Attention mechanisms, positional encoding, and the architecture behind GPT and BERT."
          href={`${base}/topics`}
          tags={['Architecture', 'Research']}
          level="expert"
          emoji="⚙️"
        />
      </div>
    </section>

    <!-- ─── CALLOUTS ─── -->
    <section id="callouts" style="margin-bottom:4rem;">
      <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;">Callouts</h2>
      <div style="display:flex;flex-direction:column;gap:0.75rem;">
        <Callout type="success" title="Success / Beginner tip">
          Great news! You don't need a PhD to understand this. Start here and work your way up.
        </Callout>
        <Callout type="info" title="Info / Prerequisite">
          This section assumes you know basic Python and have heard of neural networks before.
        </Callout>
        <Callout type="warning" title="Warning / Gotcha">
          LLMs can hallucinate — they may confidently state incorrect information. Always verify critical facts.
        </Callout>
        <Callout type="tip" title="Expert note">
          The Universal Approximation Theorem guarantees expressivity, but not learnability via gradient descent.
        </Callout>
      </div>
    </section>

    <!-- ─── CODE ─── -->
    <section id="code" style="margin-bottom:4rem;">
      <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;">Code Blocks</h2>
      <CodeBlock lang="python" filename="example.py">{`import torch
import torch.nn as nn

# A simple feedforward neural network
class MLP(nn.Module):
    def __init__(self, input_dim: int, hidden_dim: int, output_dim: int):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.GELU(),
            nn.Dropout(0.1),
            nn.Linear(hidden_dim, output_dim),
        )

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        return self.net(x)

model = MLP(784, 256, 10)
print(f"Parameters: {sum(p.numel() for p in model.parameters()):,}")`}</CodeBlock>

      <CodeBlock lang="bash" filename="terminal">{`# Install PyTorch with CUDA support
pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121

# Train your model
python train.py --epochs 10 --lr 1e-3 --batch-size 64`}</CodeBlock>
    </section>

    <!-- ─── FORMS ─── -->
    <section id="forms" style="margin-bottom:4rem;">
      <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;">Form Elements</h2>
      <div class="card" style="padding:2rem;max-width:520px;">
        <div style="margin-bottom:1.25rem;">
          <label style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.4rem;color:var(--color-text);">Search Topics</label>
          <div style="position:relative;">
            <svg style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:var(--color-text-subtle);" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input type="search" placeholder="e.g. neural networks, GPT…" class="search-input" style="padding-left:2.25rem;" aria-label="Search topics" />
          </div>
        </div>

        <div style="margin-bottom:1.25rem;">
          <label style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.4rem;color:var(--color-text);">Text Input</label>
          <input type="text" placeholder="Your name or username" style="width:100%;padding:0.6rem 0.875rem;background:var(--color-bg-card);border:1px solid var(--color-border);border-radius:8px;color:var(--color-text);font-size:0.9rem;outline:none;transition:border-color 0.15s;" onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--color-border)'" />
        </div>

        <div style="margin-bottom:1.25rem;">
          <label style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.4rem;color:var(--color-text);">Select Level</label>
          <select style="width:100%;padding:0.6rem 0.875rem;background:var(--color-bg-card);border:1px solid var(--color-border);border-radius:8px;color:var(--color-text);font-size:0.9rem;outline:none;" aria-label="Select knowledge level">
            <option>🌱 Beginner</option>
            <option>⚡ Intermediate</option>
            <option>🔬 Expert</option>
          </select>
        </div>

        <div style="margin-bottom:1.5rem;">
          <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.875rem;color:var(--color-text);">
            <label class="toggle">
              <input type="checkbox" checked aria-label="Enable notifications" />
              <span class="toggle-slider"></span>
            </label>
            Save my knowledge level preference
          </label>
        </div>

        <button class="btn btn-primary" style="width:100%;justify-content:center;">Save Preferences</button>
      </div>
    </section>

    <!-- ─── TABLES ─── -->
    <section id="tables" style="margin-bottom:4rem;">
      <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;">Data Tables</h2>
      <div class="card" style="padding:0;overflow:hidden;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Model</th>
              <th>Parameters</th>
              <th>Context Window</th>
              <th>Architecture</th>
              <th>Level</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['GPT-2', '1.5B', '1,024 tokens', 'Decoder-only', 'intermediate'],
              ['GPT-3', '175B', '4,096 tokens', 'Decoder-only', 'intermediate'],
              ['LLaMA 3 8B', '8B', '128k tokens', 'Decoder-only', 'beginner'],
              ['GPT-4', '~1T (est.)', '128k tokens', 'MoE (est.)', 'expert'],
              ['Claude 3.5', 'Unknown', '200k tokens', 'Constitutional AI', 'expert'],
            ].map(([model, params, ctx, arch, level]) => (
              <tr>
                <td><strong>{model}</strong></td>
                <td style="font-family:'JetBrains Mono',monospace;font-size:0.82rem;">{params}</td>
                <td style="font-family:'JetBrains Mono',monospace;font-size:0.82rem;">{ctx}</td>
                <td>{arch}</td>
                <td><span class={`badge badge-${level}`}>{level === 'beginner' ? '🌱' : level === 'intermediate' ? '⚡' : '🔬'} {level.charAt(0).toUpperCase() + level.slice(1)}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ─── LEVEL SELECTOR ─── -->
    <section id="levels" style="margin-bottom:4rem;">
      <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;">Knowledge Level Selector</h2>
      <div class="card" style="padding:2rem;">
        <div style="max-width:420px;">
          <div class="level-tabs" role="tablist" aria-label="Demo level selector">
            <button class="level-tab active-beginner" data-level="beginner" role="tab" aria-selected="true">🌱 Beginner</button>
            <button class="level-tab" data-level="intermediate" role="tab" aria-selected="false">⚡ Intermediate</button>
            <button class="level-tab" data-level="expert" role="tab" aria-selected="false">🔬 Expert</button>
          </div>
        </div>

        <div style="margin-top:1.25rem;padding:1.25rem;background:var(--color-bg-subtle);border-radius:10px;border:1px solid var(--color-border);">
          <div id="demo-panel-beginner" class="level-panel active">
            <span class="badge badge-beginner" style="margin-bottom:0.75rem;display:inline-flex;">🌱 Beginner Mode</span>
            <p style="font-size:0.9rem;color:var(--color-text-muted);">Simple analogies and plain language. No prior knowledge needed. Perfect for product managers, executives, or anyone curious about AI.</p>
          </div>
          <div id="demo-panel-intermediate" class="level-panel">
            <span class="badge badge-intermediate" style="margin-bottom:0.75rem;display:inline-flex;">⚡ Intermediate Mode</span>
            <p style="font-size:0.9rem;color:var(--color-text-muted);">Core technical concepts, architecture overviews, and code examples. For developers and data professionals with some AI background.</p>
          </div>
          <div id="demo-panel-expert" class="level-panel">
            <span class="badge badge-expert" style="margin-bottom:0.75rem;display:inline-flex;">🔬 Expert Mode</span>
            <p style="font-size:0.9rem;color:var(--color-text-muted);">Full mathematical derivations, research paper references, implementation details, and edge cases. Everything we know.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── PROGRESS ─── -->
    <section style="margin-bottom:4rem;">
      <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;">Progress Indicators</h2>
      <div class="card" style="padding:2rem;display:flex;flex-direction:column;gap:1.25rem;">
        {[
          { label: 'Neural Networks', value: 85 },
          { label: 'Transformers', value: 60 },
          { label: 'Reinforcement Learning', value: 30 },
        ].map(item => (
          <div>
            <div style="display:flex;justify-content:space-between;margin-bottom:0.4rem;font-size:0.82rem;">
              <span style="font-weight:600;color:var(--color-text);">{item.label}</span>
              <span style="color:var(--color-text-muted);">{item.value}%</span>
            </div>
            <div class="progress-bar-track">
              <div class="progress-bar-fill" style={`width:${item.value}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── SKELETON ─── -->
    <section style="margin-bottom:4rem;">
      <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;">Loading States</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.25rem;">
        {[1,2,3].map(() => (
          <div class="card" style="padding:1.5rem;">
            <div class="skeleton" style="height:40px;width:40px;border-radius:50%;margin-bottom:0.75rem;"></div>
            <div class="skeleton" style="height:16px;width:70%;margin-bottom:0.5rem;"></div>
            <div class="skeleton" style="height:12px;width:100%;margin-bottom:0.25rem;"></div>
            <div class="skeleton" style="height:12px;width:85%;margin-bottom:0.25rem;"></div>
            <div class="skeleton" style="height:12px;width:60%;margin-bottom:1rem;"></div>
            <div style="display:flex;gap:0.4rem;">
              <div class="skeleton" style="height:22px;width:60px;border-radius:9999px;"></div>
              <div class="skeleton" style="height:22px;width:50px;border-radius:9999px;"></div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── DARK MODE ─── -->
    <section id="dark-mode" style="margin-bottom:4rem;">
      <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:0.4rem;">Dark Mode</h2>
      <p style="font-size:0.9rem;color:var(--color-text-muted);margin-bottom:1.5rem;">Toggle using the 🌙 button in the navbar. Automatically follows your OS preference.</p>
      <Callout type="info" title="Implementation">
        Dark mode is implemented via a <code>.dark</code> class on <code>&lt;html&gt;</code>, driven by
        <code>localStorage</code> for user preference and <code>prefers-color-scheme</code> media query for
        auto-detection. All colors use CSS custom properties that flip between light and dark values.
      </Callout>
    </section>

  </div>
</PageLayout>

<script is:inline>
// Demo level tabs (separate from the article-level selector)
(function () {
  var tabs = document.querySelectorAll('[data-level]');
  tabs.forEach(function(tab) {
    // Skip tabs that are already handled by KnowledgeLevelSelector
    if(tab.closest('.level-tabs') && !tab.closest('#levels')) return;
    tab.addEventListener('click', function() {
      var level = tab.getAttribute('data-level');
      var container = tab.closest('.card') || document;
      container.querySelectorAll('[data-level]').forEach(function(t) {
        t.classList.remove('active-beginner','active-intermediate','active-expert');
        t.setAttribute('aria-selected','false');
      });
      tab.classList.add('active-' + level);
      tab.setAttribute('aria-selected','true');
      container.querySelectorAll('.level-panel').forEach(function(p) { p.classList.remove('active'); });
      var panel = document.getElementById('demo-panel-' + level);
      if(panel) panel.classList.add('active');
    });
  });
})();
</script>
