---
export interface Props {
  activeNav?: string;
}
const { activeNav } = Astro.props;
const base = import.meta.env.BASE_URL;

const navLinks = [
  { href: `${base}/`, label: 'Home', key: 'home' },
  { href: `${base}/topics`, label: 'Topics', key: 'topics' },
  { href: `${base}/elements`, label: 'UI Elements', key: 'elements' },
];
---

<nav class="navbar" aria-label="Main navigation">
  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;display:flex;align-items:center;height:60px;gap:1.5rem;">

    <!-- Logo -->
    <a href={`${base}/`} style="display:flex;align-items:center;gap:0.6rem;text-decoration:none;flex-shrink:0;" aria-label="AIHub Home">
      <span style="width:32px;height:32px;background:linear-gradient(135deg,#4f46e5,#06b6d4);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:900;color:white;letter-spacing:-0.05em;">AI</span>
      <span style="font-size:1.1rem;font-weight:800;color:var(--color-text);letter-spacing:-0.03em;">Hub</span>
    </a>

    <!-- Desktop nav links -->
    <div class="hide-mobile" style="display:flex;align-items:center;gap:0.25rem;flex:1;">
      {navLinks.map(link => (
        <a
          href={link.href}
          style={`
            padding:0.4rem 0.85rem;
            border-radius:7px;
            font-size:0.875rem;
            font-weight:500;
            text-decoration:none;
            transition:all 0.15s;
            color:${activeNav === link.key ? 'var(--color-primary)' : 'var(--color-text-muted)'};
            background:${activeNav === link.key ? 'var(--color-primary-light)' : 'transparent'};
          `}
          aria-current={activeNav === link.key ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Right side -->
    <div style="display:flex;align-items:center;gap:0.75rem;margin-left:auto;">
      <!-- Search trigger -->
      <button
        id="search-trigger"
        class="btn btn-ghost hide-mobile"
        style="gap:0.5rem;padding:0.4rem 0.85rem;font-size:0.8rem;"
        aria-label="Open search"
      >
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        Search…
        <kbd style="font-size:0.7rem;padding:0.1rem 0.35rem;background:var(--color-bg-subtle);border:1px solid var(--color-border);border-radius:4px;color:var(--color-text-subtle);">⌘K</kbd>
      </button>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="btn btn-ghost"
        style="padding:0.4rem 0.6rem;font-size:1rem;"
        aria-label="Toggle dark mode"
      >
        <span id="theme-icon">🌙</span>
      </button>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="btn btn-ghost hide-desktop"
        style="padding:0.4rem 0.6rem;"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M3 12h18M3 6h18M3 18h18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    style="display:none;border-top:1px solid var(--color-border);background:var(--color-bg-card);"
  >
    <div style="padding:0.75rem 1.5rem;display:flex;flex-direction:column;gap:0.25rem;">
      {navLinks.map(link => (
        <a
          href={link.href}
          style={`
            padding:0.6rem 0.75rem;
            border-radius:7px;
            font-size:0.9rem;
            font-weight:500;
            text-decoration:none;
            color:${activeNav === link.key ? 'var(--color-primary)' : 'var(--color-text)'};
            background:${activeNav === link.key ? 'var(--color-primary-light)' : 'transparent'};
          `}
        >
          {link.label}
        </a>
      ))}
      <!-- Mobile search -->
      <div style="position:relative;margin-top:0.5rem;">
        <svg style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:var(--color-text-subtle);" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="search" placeholder="Search topics…" class="search-input" style="font-size:0.875rem;" aria-label="Search topics" />
      </div>
    </div>
  </div>
</nav>

<!-- Search modal -->
<div id="search-modal" style="display:none;position:fixed;inset:0;z-index:100;padding:6rem 1rem 1rem;" aria-modal="true" role="dialog" aria-label="Search">
  <div style="position:absolute;inset:0;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);" id="search-backdrop"></div>
  <div style="position:relative;max-width:600px;margin:0 auto;background:var(--color-bg-card);border-radius:14px;border:1px solid var(--color-border);box-shadow:0 25px 50px -12px rgba(0,0,0,0.3);overflow:hidden;">
    <div style="position:relative;padding:1rem;">
      <svg style="position:absolute;left:1.75rem;top:50%;transform:translateY(-50%);color:var(--color-text-subtle);" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input id="search-modal-input" type="search" placeholder="Search AI topics…" class="search-input" style="padding-left:3rem;font-size:1rem;" autofocus aria-label="Search AI topics" />
    </div>
    <div style="border-top:1px solid var(--color-border);padding:0.75rem;max-height:400px;overflow-y:auto;" id="search-results">
      <p style="text-align:center;padding:2rem;color:var(--color-text-subtle);font-size:0.875rem;">Start typing to search…</p>
    </div>
    <div style="border-top:1px solid var(--color-border);padding:0.5rem 1rem;display:flex;gap:1rem;font-size:0.75rem;color:var(--color-text-subtle);">
      <span><kbd style="padding:0.1rem 0.35rem;background:var(--color-bg-subtle);border:1px solid var(--color-border);border-radius:4px;">↵</kbd> open</span>
      <span><kbd style="padding:0.1rem 0.35rem;background:var(--color-bg-subtle);border:1px solid var(--color-border);border-radius:4px;">Esc</kbd> close</span>
    </div>
  </div>
</div>

<script is:inline>
(function(){
  // Mobile menu
  var btn = document.getElementById('mobile-menu-btn');
  var menu = document.getElementById('mobile-menu');
  if(btn && menu){
    btn.addEventListener('click', function(){
      var open = menu.style.display === 'block';
      menu.style.display = open ? 'none' : 'block';
      btn.setAttribute('aria-expanded', String(!open));
    });
  }

  // Search modal
  var trigger = document.getElementById('search-trigger');
  var modal = document.getElementById('search-modal');
  var backdrop = document.getElementById('search-backdrop');
  var input = document.getElementById('search-modal-input');

  var searchData = [
    {title:'Neural Networks', href:'topics/neural-networks', desc:'How AI learns through layers of connected nodes'},
    {title:'Large Language Models', href:'topics/large-language-models', desc:'The technology behind ChatGPT and modern AI assistants'},
    {title:'Machine Learning', href:'topics/machine-learning', desc:'Teaching computers to learn from data'},
    {title:'Deep Learning', href:'topics/deep-learning', desc:'Neural networks with many layers'},
    {title:'Transformer Architecture', href:'topics/transformers', desc:'The architecture that revolutionized NLP'},
    {title:'Reinforcement Learning', href:'topics/reinforcement-learning', desc:'Learning through trial and reward'},
  ];

  function openSearch(){
    if(!modal) return;
    modal.style.display = 'block';
    setTimeout(function(){ if(input) input.focus(); }, 50);
    document.body.style.overflow = 'hidden';
  }
  function closeSearch(){
    if(!modal) return;
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }

  if(trigger) trigger.addEventListener('click', openSearch);
  if(backdrop) backdrop.addEventListener('click', closeSearch);

  document.addEventListener('keydown', function(e){
    if((e.metaKey || e.ctrlKey) && e.key === 'k'){ e.preventDefault(); openSearch(); }
    if(e.key === 'Escape') closeSearch();
  });

  if(input){
    var resultsEl = document.getElementById('search-results');
    input.addEventListener('input', function(){
      var q = input.value.toLowerCase().trim();
      if(!resultsEl) return;
      if(!q){ resultsEl.innerHTML = '<p style="text-align:center;padding:2rem;color:var(--color-text-subtle);font-size:0.875rem;">Start typing to search…</p>'; return; }
      var base = document.querySelector('base') ? document.querySelector('base').href : '/aihub/';
      var matches = searchData.filter(function(d){ return d.title.toLowerCase().includes(q) || d.desc.toLowerCase().includes(q); });
      if(!matches.length){ resultsEl.innerHTML = '<p style="text-align:center;padding:2rem;color:var(--color-text-subtle);font-size:0.875rem;">No results found</p>'; return; }
      resultsEl.innerHTML = matches.map(function(d){
        return '<a href="/aihub/'+d.href+'" style="display:block;padding:0.75rem 1rem;border-radius:8px;text-decoration:none;transition:background 0.1s;" onmouseover="this.style.background=\'var(--color-bg-subtle)\'" onmouseout="this.style.background=\'transparent\'">'
          +'<div style="font-weight:600;font-size:0.9rem;color:var(--color-text);">'+d.title+'</div>'
          +'<div style="font-size:0.8rem;color:var(--color-text-muted);margin-top:0.1rem;">'+d.desc+'</div>'
          +'</a>';
      }).join('');
    });
  }
})();
</script>
