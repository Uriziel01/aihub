---
export interface Props {
  title: string;
  description: string;
  href: string;
  tags?: string[];
  level?: 'beginner' | 'intermediate' | 'expert' | 'all';
  emoji?: string;
}
const { title, description, href, tags = [], level = 'all', emoji = '🧠' } = Astro.props;

const levelConfig = {
  beginner: { label: '🌱 Beginner', class: 'badge-beginner' },
  intermediate: { label: '⚡ Intermediate', class: 'badge-intermediate' },
  expert: { label: '🔬 Expert', class: 'badge-expert' },
  all: { label: '🎓 All Levels', class: 'badge-intermediate' },
};
const lv = levelConfig[level] || levelConfig.all;
---

<a href={href} class="card" style="display:block;padding:1.5rem;text-decoration:none;height:100%;">
  <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:0.75rem;">
    <span style="font-size:2rem;line-height:1;">{emoji}</span>
    <span class={`badge ${lv.class}`}>{lv.label}</span>
  </div>
  <h3 style="font-size:1.05rem;font-weight:700;color:var(--color-text);margin-bottom:0.4rem;">{title}</h3>
  <p style="font-size:0.85rem;color:var(--color-text-muted);line-height:1.55;margin-bottom:1rem;">{description}</p>
  {tags.length > 0 && (
    <div style="display:flex;flex-wrap:wrap;gap:0.4rem;">
      {tags.map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  )}
</a>
