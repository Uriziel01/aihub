---
export interface Props {
  lang?: string;
  filename?: string;
}
const { lang = 'python', filename } = Astro.props;
---

<div class="code-block" style="margin:1rem 0;">
  <div class="code-block-header">
    <span class="code-block-dot" style="background:#ff5f57;"></span>
    <span class="code-block-dot" style="background:#febc2e;"></span>
    <span class="code-block-dot" style="background:#28c840;"></span>
    {filename && <span style="margin-left:0.5rem;font-size:0.75rem;color:#6b7280;font-family:'JetBrains Mono',monospace;">{filename}</span>}
    {!filename && <span style="margin-left:0.5rem;font-size:0.75rem;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;">{lang}</span>}
  </div>
  <pre><code class={`language-${lang}`}><slot /></code></pre>
</div>
